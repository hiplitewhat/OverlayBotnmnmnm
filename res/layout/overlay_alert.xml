<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/card_bg"
    android:elevation="16dp">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:padding="3dp">

        <!-- Top neon bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/sakura_pink" />

        <!-- Header row: NEW badge + title + dismiss -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/badge_new"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alert_tag_default"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@color/sakura_pink"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/alert_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/alert_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/neon_cyan"
                android:shadowColor="@color/neon_cyan"
                android:shadowRadius="6"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/btn_dismiss"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textSize="16sp"
                android:textColor="@color/alert_red"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Anime title + EP number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/anime_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Anime Title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white_text"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/ep_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EP ?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/accent_gold"
                android:shadowColor="@color/accent_gold"
                android:shadowRadius="4"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Episode subtitle -->
        <TextView
            android:id="@+id/ep_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/neon_cyan"
            android:alpha="0.7"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neon_magenta"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:alpha="0.4" />

        <!-- Body -->
        <TextView
            android:id="@+id/alert_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/white_text"
            android:alpha="0.85"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:lineSpacingExtra="2dp" />

        <!-- Tags -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tag_airing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alert_airing"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/alert_green"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tag_subbed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alert_subbed"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/neon_cyan"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

            <!-- Score from AniList -->
            <TextView
                android:id="@+id/tag_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent_gold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginStart="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/btn_watch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/alert_action_watch"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@color/neon_cyan"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btn_later"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/alert_action_dismiss"
                android:textSize="13sp"
                android:textColor="@color/white_text"
                android:background="@color/deep_purple"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Bottom neon bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/neon_cyan" />

    </LinearLayout>
</FrameLayout>
